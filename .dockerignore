# Version control
.git/
.gitignore

# CI/CD and IDE
.github/
.vscode/
.agents/

# Dependencies and build output (rebuilt in container)
node_modules/
dist/

# Documentation (not needed in image)
*.md
!README.md

# Docker meta
.dockerignore
docker-compose.yml

# Deployment configs for other platforms
