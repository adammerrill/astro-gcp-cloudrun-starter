#!/usr/bin/env sh
# Native pre-commit secret gate (no Python/pre-commit framework needed).
# Enable once with:  git config core.hooksPath .githooks
# Requires gitleaks (https://github.com/gitleaks/gitleaks). Blocks the commit if a
# secret pattern is found in the STAGED diff, using the repo's .gitleaks.toml.

if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --redact --config .gitleaks.toml; then
    echo ""
    echo "❌ gitleaks: a potential secret was found in your staged changes — commit blocked."
    echo "   Review above. If it's a real secret: remove it and ROTATE it at the source."
    echo "   If it's a confirmed false positive: add it to the allowlist in .gitleaks.toml."
    exit 1
  fi
else
  echo "⚠ gitleaks not installed — skipping local secret scan."
  echo "  Install: https://github.com/gitleaks/gitleaks  (CI + GitHub push protection still apply)."
fi
