---
/**
 * Renders schema.org JSON-LD <script> blocks for the page.
 * Each item is a plain object built by ~/utils/schema (config-driven).
 * Validate output with Google's Rich Results Test after deploy.
 */
interface Props {
  items?: Record<string, unknown>[];
}

const { items = [] } = Astro.props;
const valid = items.filter(Boolean);
---

{valid.map((item) => <script type="application/ld+json" is:inline set:html={JSON.stringify(item)} />)}
