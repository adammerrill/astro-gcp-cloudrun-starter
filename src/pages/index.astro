---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import {
  getSoftwareApplicationSchema,
  getFAQSchema,
  getBreadcrumbSchema,
  absoluteUrl,
  type FaqItem,
} from '~/utils/schema';

const metadata = {
  title: 'astro-gcp-cloudrun-starter — Deploy Astro to Google Cloud Run, keyless & cost-optimized',
  ignoreTitleTemplate: true,
};

// Single source of truth for the FAQ — rendered on-page AND emitted as
// schema.org FAQPage so AI engines can extract each Q&A as a citable fact.
const faqItems: FaqItem[] = [
  {
    title: 'How much does the demo cost to run?',
    description:
      'Effectively ~$0/month. With min-instances = 0 the service scales to zero and is not billed while idle, and a low-traffic static demo stays within Cloud Run’s perpetual free tier. A billing budget alert is created automatically as a backstop. (An estimate, not a guarantee — model your traffic with the GCP pricing calculator.)',
  },
  {
    title: 'Is it safe that the repo is public?',
    description:
      'Yes — that’s the core design. Identity is keyless via Workload Identity Federation, so there is no service-account key to leak. No secrets live in files, history, or CI logs; only placeholder .example files are committed.',
  },
  {
    title: 'What does “keyless” actually mean?',
    description:
      'GitHub Actions presents an OIDC token that GCP exchanges for a short-lived credential at deploy time. The WIF provider only trusts tokens from this exact repository, so no other repo — even under the same owner — can assume the deploy identity.',
  },
  {
    title: 'What do I need to deploy it myself?',
    description:
      'A GCP billing account, the gcloud CLI, Terraform, and Docker. Follow the Setup Playbook and the Fresh User Walkthrough: bootstrap → shared → dev → set GitHub Variables → push to main. About 30–45 minutes of active work.',
  },
  {
    title: 'Can I use my own framework instead of Astro?',
    description:
      'Yes. The root Dockerfile is the contract: build your app and serve it on port 8080. Swap the source and the build steps; the Terraform foundation and CI are framework-agnostic.',
  },
  {
    title: 'How do I add a custom domain or a backend later?',
    description:
      'The template ships feature-gated modules for DNS, Load Balancer, Cloud Armor, VPC, and Cloud SQL — all disabled by default for cost. Enable them in your tfvars when you actually need them.',
  },
];

// Multiple valid schema types raise citability (CMU GEO, KDD 2024).
const structuredData = [
  getSoftwareApplicationSchema(),
  getFAQSchema(faqItems),
  getBreadcrumbSchema([{ name: 'Home', url: absoluteUrl('/') }]),
];
---

<Layout metadata={metadata} structuredData={structuredData}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Use this template',
        href: 'https://github.com/adammerrill/astro-gcp-cloudrun-starter',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      { text: 'How it works', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'astro-gcp-cloudrun-starter Hero Image' }}
  >
    <Fragment slot="title">
      Ship Astro to <span class="hidden xl:inline">Google</span>
      <span class="text-accent dark:text-white"> Cloud Run</span> — keyless &amp; cost-optimized
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">astro-gcp-cloudrun-starter</span> is a production-ready, zero-secrets template: an Astro
        v6 + Tailwind CSS v4 site, a complete Terraform foundation, and keyless GitHub Actions deploys to Google Cloud Run.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Astro → Cloud Run, keyless &amp; ~$0/mo.</span>
      Workload Identity Federation, scale-to-zero economics, and a hardened, fully reproducible IaC stack.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Principles:" description="Keyless identity · Reproducible IaC · Scale-to-zero by default" />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="What you get"
    title="A secure, cheap path from repo to public URL"
    subtitle="Everything needed to stand up a containerized web app on Cloud Run — with no service-account keys, no secrets in git, and a perpetual-free-tier cost profile."
    items={[
      {
        title: 'Keyless Workload Identity Federation',
        description:
          'GitHub Actions exchanges its OIDC token for short-lived GCP credentials at deploy time. No service-account JSON keys exist anywhere — nothing to leak from a public repo. The WIF provider is scoped to this exact repository.',
        icon: 'tabler:key-off',
      },
      {
        title: 'Terraform-managed infrastructure',
        description:
          'Bootstrap, shared, and per-environment layers provision projects, Artifact Registry, Cloud Run, IAM, monitoring, logging, and budgets. State lives in GCS. Every change is reviewable and reproducible.',
        icon: 'tabler:cube',
      },
      {
        title: 'Scale-to-zero cost optimization',
        description:
          'min-instances = 0, a low max-instances cap, the smallest sensible CPU/memory, and a billing budget with alerts. An idle public demo costs effectively ~$0/month within the perpetual free tier.',
        icon: 'tabler:coin',
      },
      {
        title: 'Zero secrets in the repo',
        description:
          'Identity is keyless; app runtime secrets (if any) live in Google Secret Manager, injected into Cloud Run. Only placeholder .example files are committed — real values stay in GitHub Variables and your untracked tfvars.',
        icon: 'tabler:lock',
      },
      {
        title: 'Security-hardened by default',
        description:
          'Non-root, multi-stage container (~25MB nginx image), least-privilege deploy identity that cannot alter infrastructure, repo-scoped federation, and feature-gated network/DB modules off on day one.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Astro v6 + Tailwind CSS v4',
        description:
          'A fast, SEO-friendly static site with a blog, RSS, image optimization, and dark mode — built with the latest Astro and Tailwind, served by nginx on Cloud Run.',
        icon: 'tabler:rocket',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Architecture"
    title="Bootstrap → Shared → Environment, all in Terraform"
    items={[
      {
        title: 'Two-stage bootstrap',
        description:
          'A one-time seed creates the GCP projects, a GCS state bucket, and an automation service account, then migrates its own state into GCS.',
      },
      {
        title: 'Shared layer',
        description:
          'Provisions the Workload Identity pool/provider, the GitHub deploy service account, and the Artifact Registry that every environment pulls from.',
      },
      {
        title: 'Environment layers',
        description:
          'dev / staging / prod each adopt their bootstrap-created project and stand up Cloud Run, IAM, monitoring, logging, and a billing budget — feature-gated extras off by default.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?ixlib=rb-4.0.3&auto=format&fit=crop&w=2072&q=80',
      alt: 'Cloud infrastructure',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Reproducible from the seed up</h3>
      A new engineer can stand up an identical environment from the Setup Playbook and the Terraform configuration — with
      zero tribal knowledge.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Keyless deploy flow',
        description:
          'Push to main → GitHub Actions authenticates via WIF → builds the Astro container → pushes to Artifact Registry → deploys a new Cloud Run revision → smoke-tests the public URL.',
      },
      {
        title: 'App-deploy-only CI',
        description:
          'The pipeline only ships images; it cannot modify infrastructure. Terraform is run deliberately from a controlled environment, keeping the deploy identity least-privilege.',
      },
      {
        title: 'Cost guardrails baked in',
        description:
          'A per-project billing budget with 50/80/100% alerts and a low max-instances cap mean a public URL anyone can hit cannot autoscale into a surprise bill.',
      },
      {
        title: 'Verified secret-clean',
        description:
          'No real IDs, keys, or secrets in files, history, or CI logs — only the intended public demo URL and committed .example placeholders.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1518770660439-4636190af475?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Pipeline and circuitry',
    }}
  >
    <Fragment slot="content"
      >Built so there is nothing sensitive to expose, and nothing costly to leave running.</Fragment
    >

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="From template to a live, public Cloud Run URL — in about 30–45 minutes."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Use this template</span>',
        description:
          "Click 'Use this template' on GitHub (or clone it). Copy each .example to its real, git-ignored counterpart and fill in your values — billing account, project prefix, region.",
        icon: 'tabler:brand-github',
      },
      {
        title: 'Step 2: <span class="font-medium">Bootstrap GCP</span>',
        description:
          'Authenticate keylessly with gcloud, run the bootstrap module to create your projects, state bucket, and automation SA, then apply the shared and dev layers with Terraform.',
        icon: 'tabler:cloud-cog',
      },
      {
        title: 'Step 3: <span class="font-medium">Wire CI &amp; deploy</span>',
        description:
          'Set the GitHub Actions Variables from your Terraform outputs (no secrets), push to main, and watch the keyless pipeline build and deploy your site to Cloud Run.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Live!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Steps image',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="What's in the box"
    subtitle="A complete, modular Terraform foundation plus a polished Astro front end."
    tagline="The stack"
    items={[
      {
        title: 'Cloud Run',
        description:
          'Serverless container hosting with scale-to-zero, CPU throttling, and a public unauthenticated demo.',
        icon: 'flat-color-icons:template',
      },
      {
        title: 'Workload Identity Federation',
        description: 'Keyless GitHub→GCP auth, scoped to this repo. No service-account keys anywhere.',
        icon: 'flat-color-icons:approval',
      },
      {
        title: 'Artifact Registry',
        description: 'Private Docker registry in the shared project, with image retention policies.',
        icon: 'flat-color-icons:database',
      },
      {
        title: 'Terraform modules',
        description:
          'iam, cloud_run, artifact_registry, monitoring, logging, secret_manager, cost_governance, and more.',
        icon: 'flat-color-icons:document',
      },
      {
        title: 'Cost governance',
        description: 'A billing budget per project with 50/80/100% alerts — your sleep-at-night control.',
        icon: 'flat-color-icons:currency-exchange',
      },
      {
        title: 'Monitoring & logging',
        description: 'Uptime checks, an availability SLO, alert policies, and audit log export — on by default.',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: 'Secret Manager',
        description: 'For any real runtime secret — injected into Cloud Run, never near the repo.',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: 'Feature-gated extras',
        description: 'VPC, Cloud SQL, DNS, Load Balancer, Cloud Armor, Vertex AI — all off on day one for cost.',
        icon: 'flat-color-icons:advertising',
      },
      {
        title: 'Astro + nginx container',
        description: 'A ~25MB, non-root, multi-stage image serving the static build on port 8080.',
        icon: 'flat-color-icons:gallery',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="Guides & deep dives on the blog"
    information={`The blog documents how this template works — deploying to Cloud Run, the keyless Workload Identity Federation setup, the Terraform layers, and how the demo stays within the free tier.
                `}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="The questions people ask before adopting a public GCP starter template."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={faqItems}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Monthly cost (idle)', amount: '~$0' },
      { title: 'SA JSON keys', amount: '0' },
      { title: 'Time to deploy', amount: '~40m' },
      { title: 'IaC coverage', amount: '100%' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Use this template',
        href: 'https://github.com/adammerrill/astro-gcp-cloudrun-starter',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
  >
    <Fragment slot="title">
      Astro&nbsp;+&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">GCP Cloud Run</span>
    </Fragment>

    <Fragment slot="subtitle">
      Keyless, reproducible, and ~$0/month. <br class="hidden md:inline" />Branch it, configure it, and deploy your own
      in under an hour.
    </Fragment>
  </CallToAction>
</Layout>
