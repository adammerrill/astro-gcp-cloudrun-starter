# environments/dev/terraform.tfvars.example
# Copy this file to "terraform.tfvars" and fill in your values.
# Run this layer AFTER bootstrap and shared.

# GCP Billing Account ID (format: XXXXXX-XXXXXX-XXXXXX)
billing_account_id = "YOUR_BILLING_ACCOUNT_ID"

# The Dev project ID (created by the bootstrap module as PREFIX-dev)
project_id = "YOUR_PROJECT_PREFIX-dev"

# Display name for the Dev project
project_name = "YOUR_PROJECT_PREFIX Dev"

# Naming prefix for your projects and GCS state bucket (e.g. "mycompany")
project_prefix = "YOUR_PROJECT_PREFIX"

# The bootstrap module already created this project, so Terraform must ADOPT
# it (look it up), not create it. Leave this false.
create_project = false

# Primary region for resources
region = "us-central1"

# Disaster recovery backup region
dr_region = "us-east1"

# Environment identifier
environment = "dev"

# Shared infrastructure project ID
shared_project_id = "YOUR_PROJECT_PREFIX-shared"

# Service account to impersonate (created by the bootstrap module)
terraform_service_account = "sa-terraform-admin@YOUR_PROJECT_PREFIX-shared.iam.gserviceaccount.com"

# Cloud Run service name.
# IMPORTANT: this MUST equal the SERVICE_NAME GitHub Actions variable, or CI
# will deploy revisions to a different service than Terraform created.
service_name = "website"

# Cost ceiling (USD/month) — drives the billing budget + 50/80/100% alerts
monthly_budget_usd = 5

# Cloud Run limits (cost-optimized defaults: scales to zero, small, capped)
cloud_run_min_instances = 0
cloud_run_max_instances = 2
cloud_run_cpu_limit     = "0.5"
cloud_run_memory_limit  = "256Mi"

# Feature Gates (Disabled by default on Day 1 for cost-efficiency)
enable_networking    = false
enable_dns           = false
enable_cloud_armor   = false
enable_load_balancer = false
enable_cloud_sql     = false
enable_vertex_ai     = false
